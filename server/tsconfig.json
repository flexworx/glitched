{
  "compilerOptions": {
    "target": "ES2017",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "../dist/server",
    "rootDir": "..",
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["../src/*"]
    },
    "baseUrl": ".."
  },
  "include": [
    "./**/*.ts",
    "../src/lib/**/*.ts",
    "../src/services/**/*.ts"
  ]
}
