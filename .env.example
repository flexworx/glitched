# ============================================================
# GLITCHED.GG — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# Database (PostgreSQL 16 on host machine)
DATABASE_URL="postgresql://glitched:password@host.docker.internal:5432/glitched_db"

# Authentication
NEXTAUTH_SECRET="your-nextauth-secret-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# AI (Anthropic Claude)
ANTHROPIC_API_KEY="sk-ant-..."

# Blockchain (Solana)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
SOLANA_DEVNET_RPC_URL="https://api.devnet.solana.com"
SOLANA_PROGRAM_ID="your-program-id-here"
MURPH_TOKEN_MINT="your-murph-token-mint-address"
PLATFORM_WALLET_PRIVATE_KEY="your-platform-wallet-private-key"

# Voice (ElevenLabs)
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# Redis (for WebSocket pub/sub and caching)
REDIS_URL="redis://localhost:6379"

# WebSocket
NEXT_PUBLIC_WS_URL="ws://localhost:3001"

# Admin
ADMIN_SECRET="your-admin-secret-key"

# Storage (for media assets)
PINATA_API_KEY="your-pinata-api-key"
PINATA_SECRET_KEY="your-pinata-secret-key"

# CORS
ALLOWED_ORIGIN="http://localhost:3000"

# Feature Flags
NEXT_PUBLIC_ENABLE_BLOCKCHAIN="false"
NEXT_PUBLIC_ENABLE_VOICE="false"
NEXT_PUBLIC_ENABLE_BYOA="false"
NEXT_PUBLIC_MAINTENANCE_MODE="false"

# Game Engine
GAME_ENGINE_URL="http://localhost:3002"
GAME_ENGINE_SECRET="your-engine-secret"

# Monitoring
SENTRY_DSN=""
